[flake8]
max-line-length = 120
# E501 (line-too-long) is ignored globally so that long prompt strings,
# URLs, and other natural prose can be written without artificial line breaks.
# E203: whitespace before ':' (conflicts with black)
# W503: line break before binary operator (conflicts with black)
extend-ignore = E203,W503,E501
exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    node_modules
