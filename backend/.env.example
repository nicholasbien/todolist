# Backend Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# OpenAI API Configuration (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# MongoDB Configuration (Required)
# Default: mongodb://localhost:27017 for local development
# For cloud: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URL=mongodb://localhost:27017

# JWT Secret for Session Management (Required)
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# Email Configuration (Optional - prints to console if not configured)
# For Gmail:
# 1. Enable 2-factor authentication
# 2. Generate app password at: https://myaccount.google.com/apppasswords
# 3. Use the app password as SMTP_PASSWORD
FROM_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password

# Optional Email Settings (have defaults)
# SMTP_SERVER=smtp.gmail.com  # Default for Gmail
# SMTP_PORT=587               # Default TLS port

# Search API Configuration (Optional - for web search features)
# Get your API key from: https://brave.com/search/api/
BRAVE_API_KEY=your-brave-search-api-key-here

# Testing Configuration (Optional)
# USE_MOCK_DB=true  # Use this for testing without real email/DB
# ALLOW_TEST_AUTH_BYPASS=true  # Enable test email/code bypass in auth (test/dev only)
