# Backend Environment Variables Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Required
# =============================================================================

# OpenAI API Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# MongoDB Configuration
# Default: mongodb://localhost:27017 for local development
# For cloud: mongodb+srv://username:password@cluster.mongodb.net/database
MONGODB_URL=mongodb://localhost:27017

# JWT Secret for Session Management
# Generate a secure random string: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-here

# =============================================================================
# Optional — Email (prints to console if not configured)
# =============================================================================

# For Gmail: enable 2FA, then generate an app password at
# https://myaccount.google.com/apppasswords
FROM_EMAIL=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
# SMTP_SERVER=smtp.gmail.com   # Default
# SMTP_PORT=587                 # Default (TLS)

# =============================================================================
# Optional — External APIs
# =============================================================================

# Brave Search API (for web search agent tool)
# Get your API key from: https://brave.com/search/api/
# BRAVE_API_KEY=your-brave-search-api-key-here

# Website URL (used for space invitation emails)
# WEBSITE_URL=https://your-site-url.com

# =============================================================================
# Optional — Development / Testing
# =============================================================================

# Set to "true" to use an in-memory mock database (no MongoDB required)
# USE_MOCK_DB=true

# Enable the test account bypass (test@example.com / 000000)
# WARNING: Never enable in production — allows unauthenticated access
# ALLOW_TEST_ACCOUNT=true

# Override default test account credentials
# TEST_EMAIL=test@example.com
# TEST_CODE=000000
