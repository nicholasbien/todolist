#!/usr/bin/env node

/**
 * OpenClaw Todolist CLI
 * Wraps API calls for the OpenClaw skill
 * 
 * Usage:
 *   openclaw-todolist check        - Poll for pending sessions
 *   openclaw-todolist status       - Show active task assignments
 *   openclaw-todolist reply <session_id> <message> - Reply to a session
 *   openclaw-todolist sessions     - List all sessions
 *   openclaw-todolist todos        - List todos
 */

const API_URL = process.env.TODOLIST_API_URL || 'http://localhost:8141';
const AUTH_TOKEN = process.env.TODOLIST_AUTH_TOKEN;

if (!AUTH_TOKEN) {
  console.error('Error: TODOLIST_AUTH_TOKEN not set');
  process.exit(1);
}

const HEADERS = {
  'Authorization': `Bearer ${AUTH_TOKEN}`,
  'Content-Type': 'application/json'
};

async function request(method, path, body = null) {
  const opts = { method, headers: HEADERS };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`${API_URL}${path}`, opts);
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`${res.status} ${res.statusText}: ${err}`);
  }
  return res.json();
}

async function check() {
  const sessions = await request('GET', '/agent/sessions/pending?agent_id=openclaw');
  if (sessions.length === 0) {
    console.log('No pending sessions');
    return;
  }
  console.log(`\nFound ${sessions.length} pending session(s):\n`);
  sessions.forEach((s, i) => {
    console.log(`${i + 1}. ${s.title}`);
    console.log(`   ID: ${s._id}`);
    console.log(`   Todo ID: ${s.todo_id || '(none)'}`);
    console.log(`   Followup: ${s.is_followup ? 'Yes' : 'No'}`);
    console.log(`   Messages: ${s.message_count}`);
    if (s.recent_messages?.length) {
      console.log(`   Recent: ${s.recent_messages[0]?.substring(0, 80)}...`);
    }
    console.log('');
  });
}

async function status() {
  const sessions = await request('GET', '/agent/sessions?agent_id=openclaw');
  const active = sessions.filter(s => s.needs_agent_response);
  if (active.length === 0) {
    console.log('No active sessions');
    return;
  }
  console.log(`\nActive sessions (${active.length}):\n`);
  active.forEach((s, i) => {
    console.log(`${i + 1}. ${s.title}`);
    console.log(`   Session: ${s._id}`);
    console.log(`   Todo: ${s.todo_id || '(none)'}`);
    console.log('');
  });
}

async function reply(sessionId, message) {
  const result = await request('POST', `/agent/sessions/${sessionId}/messages`, {
    content: message,
    role: 'assistant',
    agent_id: 'openclaw'
  });
  console.log('Posted reply:', result.message?.content?.substring(0, 50) + '...');
}

async function listSessions() {
  const sessions = await request('GET', '/agent/sessions?agent_id=openclaw');
  console.log(`\nAll sessions (${sessions.length}):\n`);
  sessions.forEach(s => {
    const status = s.needs_agent_response ? '⚠️ PENDING' : '✅ Done';
    console.log(`${status} ${s.title} (${s._id})`);
  });
}

async function listTodos(spaceId = '69acf86990e15c7b59794961') {
  const todos = await request('GET', `/todos?space_id=${spaceId}`);
  const incomplete = todos.filter(t => !t.completed);
  console.log(`\nIncomplete todos (${incomplete.length}):\n`);
  incomplete.slice(0, 20).forEach(t => {
    console.log(`[ ] ${t.text}`);
    console.log(`   ID: ${t._id} | Category: ${t.category}`);
    console.log('');
  });
}

const cmd = process.argv[2];
const args = process.argv.slice(3);

switch (cmd) {
  case 'check':
    check().catch(e => console.error(e.message));
    break;
  case 'status':
    status().catch(e => console.error(e.message));
    break;
  case 'reply':
    if (args.length < 2) {
      console.error('Usage: openclaw-todolist reply <session_id> <message>');
      process.exit(1);
    }
    reply(args[0], args.slice(1).join(' ')).catch(e => console.error(e.message));
    break;
  case 'sessions':
    listSessions().catch(e => console.error(e.message));
    break;
  case 'todos':
    listTodos().catch(e => console.error(e.message));
    break;
  default:
    console.log(`OpenClaw Todolist CLI

Usage:
  openclaw-todolist check        Poll for pending sessions
  openclaw-todolist status       Show active task assignments
  openclaw-todolist reply <sid> <msg>  Reply to a session
  openclaw-todolist sessions     List all sessions
  openclaw-todolist todos       List incomplete todos

Environment:
  TODOLIST_API_URL    API base URL (default: http://localhost:8141)
  TODOLIST_AUTH_TOKEN JWT auth token (required)
`);
}
