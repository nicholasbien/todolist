#!/usr/bin/env node

/**
 * OpenClaw Todolist CLI
 * Wraps API calls for the OpenClaw skill
 * 
 * Usage:
 *   todolist check        - Poll for pending sessions
 *   todolist status       - Show active task assignments
 *   todolist reply <session_id> <message> - Reply to a session
 *   todolist sessions     - List all sessions
 *   todolist todos        - List todos
 *   todolist claim <session_id> - Claim a task for tracking
 *   todolist dispatch <session_id> - Dispatch task to worker (spawn subagent)
 *   todolist tasks        - Show tracked task assignments
 *   todolist release <session_id> - Release a task back to pool
 */

const API_URL = process.env.TODOLIST_API_URL || 'http://localhost:8141';
const AUTH_TOKEN = process.env.TODOLIST_AUTH_TOKEN;
const TRACKING_FILE = process.env.HOME + '/.config/openclaw-todolist/tasks.json';

if (!AUTH_TOKEN) {
  console.error('Error: TODOLIST_AUTH_TOKEN not set');
  process.exit(1);
}

const HEADERS = {
  'Authorization': `Bearer ${AUTH_TOKEN}`,
  'Content-Type': 'application/json'
};

const fs = require('fs');
const path = require('path');

// Task tracking
function loadTasks() {
  try {
    if (fs.existsSync(TRACKING_FILE)) {
      return JSON.parse(fs.readFileSync(TRACKING_FILE, 'utf8'));
    }
  } catch (e) {}
  return {};
}

function saveTasks(tasks) {
  const dir = path.dirname(TRACKING_FILE);
  if (!fs.existsSync(dir)) {
    fs.mkdirSync(dir, { recursive: true });
  }
  fs.writeFileSync(TRACKING_FILE, JSON.stringify(tasks, null, 2));
}

async function request(method, path, body = null) {
  const opts = { method, headers: HEADERS };
  if (body) opts.body = JSON.stringify(body);
  const res = await fetch(`${API_URL}${path}`, opts);
  if (!res.ok) {
    const err = await res.text();
    throw new Error(`${res.status} ${res.statusText}: ${err}`);
  }
  return res.json();
}

async function check() {
  const sessions = await request('GET', '/agent/sessions/pending?agent_id=openclaw');
  if (sessions.length === 0) {
    console.log('No pending sessions');
    return;
  }
  console.log(`\nFound ${sessions.length} pending session(s):\n`);
  sessions.forEach((s, i) => {
    console.log(`${i + 1}. ${s.title}`);
    console.log(`   ID: ${s._id}`);
    console.log(`   Todo ID: ${s.todo_id || '(none)'}`);
    console.log(`   Followup: ${s.is_followup ? 'Yes' : 'No'}`);
    console.log(`   Messages: ${s.message_count}`);
    if (s.recent_messages?.length) {
      console.log(`   Recent: ${s.recent_messages[0]?.substring(0, 80)}...`);
    }
    console.log('');
  });
}

async function status() {
  const sessions = await request('GET', '/agent/sessions?agent_id=openclaw');
  const active = sessions.filter(s => s.needs_agent_response);
  if (active.length === 0) {
    console.log('No active sessions');
    return;
  }
  console.log(`\nActive sessions (${active.length}):\n`);
  active.forEach((s, i) => {
    console.log(`${i + 1}. ${s.title}`);
    console.log(`   Session: ${s._id}`);
    console.log(`   Todo: ${s.todo_id || '(none)'}`);
    console.log('');
  });
}

async function reply(sessionId, message) {
  const result = await request('POST', `/agent/sessions/${sessionId}/messages`, {
    content: message,
    role: 'assistant',
    agent_id: 'openclaw'
  });
  console.log('Posted reply:', result.message?.content?.substring(0, 50) + '...');
}

async function listSessions() {
  const sessions = await request('GET', '/agent/sessions?agent_id=openclaw');
  console.log(`\nAll sessions (${sessions.length}):\n`);
  sessions.forEach(s => {
    const status = s.needs_agent_response ? '⚠️ PENDING' : '✅ Done';
    console.log(`${status} ${s.title} (${s._id})`);
  });
}

async function listTodos(spaceId = '69acf86990e15c7b59794961') {
  const todos = await request('GET', `/todos?space_id=${spaceId}`);
  const incomplete = todos.filter(t => !t.completed);
  console.log(`\nIncomplete todos (${incomplete.length}):\n`);
  incomplete.slice(0, 20).forEach(t => {
    console.log(`[ ] ${t.text}`);
    console.log(`   ID: ${t._id} | Category: ${t.category}`);
    console.log('');
  });
}

// Task tracking commands
async function claim(sessionId) {
  const session = await request('GET', `/agent/sessions/${sessionId}`);
  const tasks = loadTasks();
  
  // Post interim acknowledgment
  await request('POST', `/agent/sessions/${sessionId}/messages`, {
    content: "I've picked up this task. Working on it now...",
    role: 'assistant',
    agent_id: 'openclaw',
    interim: true
  });
  
  // Track the task
  tasks[sessionId] = {
    title: session.title,
    todo_id: session.todo_id,
    claimed_at: new Date().toISOString(),
    status: 'in_progress',
    worker: 'main'
  };
  saveTasks(tasks);
  console.log(`Claimed task: ${session.title}`);
}

async function dispatch(sessionId) {
  const session = await request('GET', `/agent/sessions/${sessionId}`);
  const tasks = loadTasks();
  
  // Generate a worker ID
  const workerId = 'worker-' + Date.now();
  
  // Track as dispatched
  tasks[sessionId] = {
    title: session.title,
    todo_id: session.todo_id,
    dispatched_at: new Date().toISOString(),
    status: 'dispatched',
    worker: workerId
  };
  saveTasks(tasks);
  
  console.log(`Dispatched task to worker: ${workerId}`);
  console.log(`Task: ${session.title}`);
  console.log(`Session: ${sessionId}`);
  console.log(`\nNote: Use OpenClaw's sessions_spawn to actually spawn a subagent.`);
  console.log(`This CLI tracks the mapping for you.`);
}

async function listTasks() {
  const tasks = loadTasks();
  const entries = Object.entries(tasks);
  
  if (entries.length === 0) {
    console.log('No tracked tasks');
    return;
  }
  
  console.log(`\nTracked tasks (${entries.length}):\n`);
  entries.forEach(([sessionId, task]) => {
    const statusIcon = task.status === 'done' ? '✅' : task.status === 'dispatched' ? '📤' : '🔄';
    console.log(`${statusIcon} ${task.title}`);
    console.log(`   Session: ${sessionId}`);
    console.log(`   Worker: ${task.worker}`);
    console.log(`   Status: ${task.status}`);
    if (task.claimed_at) console.log(`   Claimed: ${task.claimed_at}`);
    if (task.dispatched_at) console.log(`   Dispatched: ${task.dispatched_at}`);
    console.log('');
  });
}

async function release(sessionId) {
  const tasks = loadTasks();
  if (!tasks[sessionId]) {
    console.log('Task not found in tracking');
    return;
  }
  delete tasks[sessionId];
  saveTasks(tasks);
  console.log(`Released task: ${sessionId}`);
}

const cmd = process.argv[2];
const args = process.argv.slice(3);

switch (cmd) {
  case 'check':
    check().catch(e => console.error(e.message));
    break;
  case 'status':
    status().catch(e => console.error(e.message));
    break;
  case 'reply':
    if (args.length < 2) {
      console.error('Usage: todolist reply <session_id> <message>');
      process.exit(1);
    }
    reply(args[0], args.slice(1).join(' ')).catch(e => console.error(e.message));
    break;
  case 'sessions':
    listSessions().catch(e => console.error(e.message));
    break;
  case 'todos':
    listTodos().catch(e => console.error(e.message));
    break;
  case 'claim':
    if (!args[0]) {
      console.error('Usage: todolist claim <session_id>');
      process.exit(1);
    }
    claim(args[0]).catch(e => console.error(e.message));
    break;
  case 'dispatch':
    if (!args[0]) {
      console.error('Usage: todolist dispatch <session_id>');
      process.exit(1);
    }
    dispatch(args[0]).catch(e => console.error(e.message));
    break;
  case 'tasks':
    listTasks().catch(e => console.error(e.message));
    break;
  case 'release':
    if (!args[0]) {
      console.error('Usage: todolist release <session_id>');
      process.exit(1);
    }
    release(args[0]).catch(e => console.error(e.message));
    break;
  default:
    console.log(`OpenClaw Todolist CLI

Usage:
  todolist check              Poll for pending sessions
  todolist status             Show active task assignments
  todolist reply <sid> <msg>  Reply to a session
  todolist sessions            List all sessions
  todolist todos               List incomplete todos
  todolist claim <sid>         Claim a task for tracking
  todolist dispatch <sid>     Dispatch task to worker (spawn subagent)
  todolist tasks               Show tracked task assignments
  todolist release <sid>      Release a task back to pool

Task Tracking:
  Tasks are stored in ~/.config/openclaw-todolist/tasks.json
  The dispatch command generates a worker ID and tracks session→worker mappings

Environment:
  TODOLIST_API_URL    API base URL (default: http://localhost:8141)
  TODOLIST_AUTH_TOKEN JWT auth token (required)
`);
}
