# Todolist API Configuration
TODOLIST_API_URL=http://localhost:8000

# Authentication token for the todolist API
# Get this by logging in to your todolist app and copying the JWT token
TODOLIST_AUTH_TOKEN=your_jwt_token_here

# Note: DEFAULT_SPACE_ID is no longer needed - the server auto-detects
# the user's default space by calling /spaces on first use.
