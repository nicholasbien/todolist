# todolist App — Environment Configuration
# Copy this file to .env and fill in your values:  cp .env.example .env

# =============================================================================
# Required
# =============================================================================

# Secret key for signing JWT session tokens
# Generate one with:  openssl rand -base64 32
JWT_SECRET=change-me

# MongoDB connection string
# For Docker Compose: mongodb://mongo:27017 (set automatically)
# For local dev: mongodb://localhost:27017
MONGODB_URL=mongodb://localhost:27017

# =============================================================================
# Optional — AI Features
# =============================================================================
# The app works fully without these. AI classification, assistant, and
# email summaries are disabled when the key is not set.

# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# =============================================================================
# Optional — Email
# =============================================================================
# If not set, verification codes print to the backend console.
# For Gmail: enable 2FA, then generate an app password at
# https://myaccount.google.com/apppasswords

FROM_EMAIL=
SMTP_PASSWORD=
# SMTP_SERVER=smtp.gmail.com   # default
# SMTP_PORT=587                # default

# =============================================================================
# Optional — Web Search (Agent tool)
# =============================================================================
# Used by the AI assistant for web search. Get a key at https://brave.com/search/api/
BRAVE_API_KEY=

# =============================================================================
# Optional — Testing / Development
# =============================================================================
# Enable test account login bypass (never set in production!)
# ALLOW_TEST_ACCOUNT=true
# TEST_EMAIL=test@example.com
# TEST_CODE=000000

# CORS origins (comma-separated). Defaults to localhost + capacitor.
# CORS_ORIGINS=http://localhost:3141,capacitor://localhost,ionic://localhost
