# Frontend Environment Variables Configuration
# Copy this file to .env.local for development or .env.production for production

# Backend URL for the API proxy (server-side only, not exposed to client)
BACKEND_URL=http://localhost:8000

# Backend URL for client-side SSE streaming (bypasses Next.js proxy)
# In development, this should point to your local backend
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000

# OpenAI key for client-side features (optional)
# OPENAI_API_KEY=your-openai-api-key-here
