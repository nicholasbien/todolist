# Production environment - use relative URLs so service worker can intercept
# API requests will be proxied through Next.js API routes to the Railway backend

# Backend URL for the API proxy (not exposed to client)
BACKEND_URL=https://backend-production-e920.up.railway.app

# Don't set NEXT_PUBLIC_API_URL - this forces relative URLs
# NEXT_PUBLIC_API_URL=

# OpenAI key for client-side features
OPENAI_API_KEY=your_openai_key_here
