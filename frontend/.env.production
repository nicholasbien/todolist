# Production environment
# Set these values for your deployment (e.g., Railway, Vercel, etc.)

# Backend URL for the API proxy (not exposed to client)
BACKEND_URL=

# Backend URL for client-side SSE streaming (bypasses proxy)
NEXT_PUBLIC_BACKEND_URL=

# OpenAI key for client-side features (optional)
# OPENAI_API_KEY=your_openai_key_here
